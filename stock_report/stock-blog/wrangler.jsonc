{
	"name": "stock-blog",
	"pages_build_output_dir": "./dist/client",
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
        {
          "binding": "stock_report_db",
          "database_name": "stock-report-db",
          "database_id": "7fa1f489-75e7-4f31-b42e-d87da80d429d"
        }
    ]
}
